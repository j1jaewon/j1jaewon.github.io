\r\n \uba39\uace0\ubcf4\ub294\ud3ad\uadc4 \u30fb 2026. 4. 18. 10:30\r\n\r\n\ud83e\udd69 \uc8fc\ub9d0\uc5d0\ub3c4 \uc801\uc6a9\ub418\ub294 \ub7f0\uce58\u00b7\ud574\ud53c\uc544\uc6cc\r\n\r\n\ud83e\udd69 \uc0ac\uc774\ub4dc\ub294 \ud2b9\ubcc4\uc219\uc131\uae40\uce58 \ucd94\ucc9c\r\n\r\n\ud83e\udd69 \uc6b8\ud504\uac15 \uc2a4\ud14c\uc774\ud06c \ud558\uc6b0\uc2a4 \ub3d9\uc0dd \ube0c\ub79c\ub4dc\r\n\r\n\r\n\u200b\r\n\r\n\uadfc\ucc98 \uc9c0\ub0a0 \ub54c\ub9c8\ub2e4 \uaf2d \uac00\uc57c\uc9c0 \ud558\uace0\r\n\r\n\ub9c8\uc74c\uc5d0\ub9cc \ub2f4\uc544\ub450\uace0 \uc788\ub358 \uacf3\uc774 \uc788\uc5b4\uc694.\r\n\r\n\uc7a0\uc2e4\uc5d0 \uc0dd\uacbc\ub2e4\ub294 \uc18c\uc2dd \ub4e4\uc5c8\uc744 \ub54c\ubd80\ud130\r\n\r\n\uc740\uadfc\ud788 \ubcbc\ub974\uace0 \uc788\uc5c8\ub358 \ub189\uc2a4 \uc7a0\uc2e4\uc810\uc774\uc5d0\uc694.\r\n\r\n\ub9c8\uce68 \uc8fc\ub9d0\uc5d0\ub3c4 \ub7f0\uce58\ub791\r\n\r\n\ud574\ud53c\uc544\uc6cc\uac00 \uc801\uc6a9\ub41c\ub2e4\uace0 \ud574\uc11c\r\n\r\n\ub4dc\ub514\uc5b4 \ub2e4\ub140\uc654\uc5b4\uc694.\r\n\r\n\r\n\r\n\r\n\u200b\r\n\r\n\ub0b4\ubd80\ub294 \uc804\ubc18\uc801\uc73c\ub85c\r\n\r\n\uae54\ub054\ud558\uace0 \uc815\ub3c8\ub41c \ubd84\uc704\uae30\uc5d0\uc694.\r\n\r\n\ub108\ubb34 \uaca9\uc2dd \uc788\ub294 \ud30c\uc778\ub2e4\uc774\ub2dd \ub290\ub08c\uc740 \uc544\ub2c8\uace0,\r\n\r\n\uc801\ub2f9\ud788 \uace0\uae09\uc2a4\ub7ec\uc6b0\uba74\uc11c\ub3c4\r\n\r\n\ud3b8\uc548\ud558\uac8c \uc2dd\uc0ac\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc774\uc5d0\uc694.\r\n\r\n\u200b\r\n\r\n\ud14c\uc774\ube14 \uac04\uaca9\ub3c4 \uad1c\ucc2e\uc544\uc11c\r\n\r\n\ub300\ud654\ud558\uae30\ub3c4 \ud3b8\ud588\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\r\n\u200b\r\n\r\n\ud83d\udc49 \ub7f0\uce58 \ucf64\ubcf4(11:00~14:00)\ub791\r\n\r\n\ud83d\udc49 \ud574\ud53c\uc544\uc6cc(11:00~16:00)\uac00\r\n\r\n\uc8fc\ub9d0\uc5d0\ub3c4 \uc801\uc6a9\ub41c\ub2e4\ub294 \uc810 \ucc38\uace0\ud558\uc138\uc694!\r\n\r\n\uac00\uaca9\ub3c4 \ubd80\ub2f4\uc774 \ub35c\ud55c \ud3b8\uc774\ub77c\r\n\r\n\ubd80\ub2f4 \uc5c6\uc774 \uc624\uae30 \uc88b\uc740 \uc2a4\ud14c\uc774\ud06c \ud558\uc6b0\uc2a4\uc5d0\uc694.\r\n\r\n\u200b\r\n\r\n\uc800\ud76c\ub294 \uc5d8\ubcf8 \uc2a4\ud14c\uc774\ud06c \ucf54\uc2a4\ub97c \uc8fc\ubb38\ud588\uc5b4\uc694.\r\n\r\n\uad6c\uc131\ub9cc \ubd10\ub3c4 \uc54c\ucc2c \ucf54\uc2a4\uc5d0\uc694.\r\n\r\n\uc5d8\ubcf8 \uc2a4\ud14c\uc774\ud06c \ucf54\uc2a4 109,000\uc6d0\r\n\r\n\u2714 Dumbo Bread & Chop Salad\r\n\r\n\u2714 L-bone Steak 500g\r\n\r\n\u2714 \uc0ac\uc774\ub4dc 3\uc885\r\n\r\n\u3000(\ub9e4\uc26c \ud3ec\ud14c\uc774\ud1a0, \uadf8\ub9b4\ub4dc \ubaa8\ub4ec \uc57c\ucc44,\r\n\r\n\ud2b9\ubcc4\uc219\uc131\uae40\uce58)\r\n\r\n\u2714 \ud30c\uc2a4\ud0c0 & \ub77c\uc774\uc2a4 \uc911 1\r\n\r\n(\uc26c\ub9bc\ud504 \ub85c\uc81c \ub9ac\uac00\ud1a0\ub2c8)\r\n\r\n\u2714 \uc74c\ub8cc 2\uc794(\uc81c\ub85c\ucf5c\ub77c)\r\n\r\n\u200b\r\n\r\n\u200b\r\n\r\n\r\n\r\n\u200b\r\n\r\n\ub364\ubcf4 \ube0c\ub798\ub4dc\r\n\r\n\uc774 \uce5c\uad6c\ub294\r\n\r\n\uac19\uc774 \ub098\uc628 \ubc84\ud130\uac00 \uc9c4\uc9dc \ud3ec\uc778\ud2b8\uc5d0\uc694.\r\n\r\n\uace0\uc18c\ud558\uace0 \ubd80\ub4dc\ub7ec\uc6cc\uc11c\r\n\r\n\ube75\uc774\ub791 \ub108\ubb34 \uc798 \uc5b4\uc6b8\ub838\uc5b4\uc694.\r\n\r\n\uc2dc\uc791\ubd80\ud130 \ube75 \ud3ed\ud48d\ud761\uc785\ud588\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n \r\n\r\n\u200b\r\n\r\n\uc81c\ub85c\ucf5c\ub77c\ub294\r\n\r\n\uc0ac\uc774\uc988\uac00 \uc0dd\uac01\ubcf4\ub2e4 \ucee4\uc11c \ub180\ub790\uc5b4\uc694.\r\n\r\n\uc774\ub807\uac8c \ud070\ub370\r\n\r\n\ub9ac\ud544\ub3c4 \ud55c \ubc88 \uac00\ub2a5\ud558\ub2e4\uace0 \ud558\ub354\ub77c\uace0\uc694.\r\n\r\n\u200b\r\n\r\n\r\n \r\n\r\n\u200b\r\n\r\n\ucc39 \uc0d0\ub7ec\ub4dc\r\n\r\n\uc758\uc678\ub85c \ub9cc\uc871\ub3c4\uac00 \uc815\ub9d0 \ub192\uc558\ub358 \uba54\ub274\uc608\uc694.\r\n\r\n\uc911\uac04\uc911\uac04 \ub4e4\uc5b4\uac04 \uce58\uc988 \ub355\ubd84\uc5d0\r\n\r\n\uc2ec\uc2ec\ud558\uc9c0 \uc54a\uace0, \ucc44\uc18c\uac00 \uc804\ubd80\r\n\r\n\uc2e0\uc120\ud558\uace0 \uc218\ubd84\uac10\uc774 \uc0b4\uc544 \uc788\uc5b4\uc11c\r\n\r\n\uba39\uc744\uc218\ub85d \uae30\ubd84 \uc88b\uc544\uc9c0\ub294 \uc0d0\ub7ec\ub4dc\uc600\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\uace0\uae30 \ub098\uc624\uae30 \uc804\r\n\r\n\uc785 \ud480\uae30\uc6a9\uc73c\ub85c \ub531\uc774\uc5d0\uc694.\r\n\r\n\u200b\r\n\r\n \r\n \r\n\r\n\u200b\r\n\r\n\uc0ac\uc774\ub4dc \uba54\ub274 3\uc885\r\n\r\n\ub9e4\uc26c \ud3ec\ud14c\uc774\ud1a0, \uadf8\ub9b4\ub4dc \ubaa8\ub4ec \uc57c\ucc44,\r\n\r\n\ud2b9\ubcc4\uc219\uc131\uae40\uce58\uae4c\uc9c0.\r\n\r\n\uc14b \ub2e4 \ube60\uc9d0\uc5c6\uc774 \ub9cc\uc871\uc2a4\ub7ec\uc6e0\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\ud2b9\ud788 \ub9e4\uc26c \ud3ec\ud14c\uc774\ud1a0\ub294\r\n\r\n\ub4a4\uc5d0 \ub098\uc62c \uace0\uae30\ub97c \uc704\ud55c\r\n\r\n\uc644\ubcbd\ud55c \uc9dd\uc774\uc5c8\uc5b4\uc694.\r\n\r\n\uae40\uce58\ub3c4 \ub290\ub07c\ud568 \uc7a1\uc544\uc918\uc11c\r\n\r\n\uc815\ub9d0 \uaf2d \uc8fc\ubb38\ud574\uc57c\ud574\uc694.\r\n\r\n\u200b\r\n\r\n\r\n \r\n\r\n\u200b\r\n\r\n\uc5d8\ubcf8 \uc2a4\ud14c\uc774\ud06c (500g)\r\n\r\n\ub4dc\ub514\uc5b4 \uba54\uc778\uc778 \uc5d8\ubcf8 \uc2a4\ud14c\uc774\ud06c\uc5d0\uc694.\r\n\r\n\uad7d\uae30\ub294 \uc9c4\ub9ac\uc758 \ubbf8\ub514\uc6c0 \ub808\uc5b4\ub85c \uc8fc\ubb38\uc744 \ud588\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n \r\n \r\n\r\n\u200b\r\n\r\n\uace0\uae30\ub294 \uc804\uccb4\uc801\uc73c\ub85c \ub2f4\ubc31\ud55c \uc2a4\ud0c0\uc77c\uc774\uc5d0\uc694.\r\n\r\n\uadf8\ub0e5 \uba39\uc5b4\ub3c4 \ub9db\uc788\uace0,\r\n\r\n\uc18c\uc2a4\ub791 \uacc1\ub4e4\uc5ec \uba39\uc5b4\ub3c4 \ub9db\uc788\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\uac89\uba74\uc774 \uc0b4\uc9dd \ub4dc\ub77c\uc774\ud574\uc11c \uc544\uc26c\uc6e0\uc9c0\ub9cc\r\n\r\n\uc5d8\ubcf8 \ubd80\uc704 \ud2b9\uc131 \uc0dd\uac01\ud558\uba74\r\n\r\n\ubd80\ub2f4 \uc5c6\uc774 \uba39\uae30 \uc88b\uc740 \ub290\ub08c\uc774\uc5c8\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\r\n \r\n\r\n\u200b\r\n\r\n\uadf8\ub9ac\uace0 \uc624\ub298\uc758 \ucd5c\uace0 \uc870\ud569\uc740\r\n\r\n\ub9e4\uc26c \ud3ec\ud14c\uc774\ud1a0 + \uc2a4\ud14c\uc774\ud06c\uc5d0\uc694.\r\n\r\n\uc774 \uc870\ud569\uc744 \ud55c \uc785 \uba39\ub294 \uc21c\uac04\r\n\r\n\uc7a0\uae50 \ubbf8\uad6d \ub2e4\ub140\uc628 \ub290\ub08c\uc774 \ub4e4\uc5c8\uc5b4\uc694.\r\n\r\n\uad1c\ud788 \uc6b8\ud504\uac15 \ub3d9\uc0dd \ube0c\ub79c\ub4dc\uac00 \uc544\ub2c8\ub354\ub77c\uad6c\uc694!\r\n\r\n(DC \ub808\uc2a4\ud1a0\ub791 \uc704\ud06c\uac00 \ub108\ubb34 \uadf8\ub9ac\uc6b4 \ubaa8\uba3c\ud2b8\u3160\u3160)\r\n\r\n\u200b\r\n\r\n\r\n\u200b\r\n\r\n\ucc38\uace0\ub85c\r\n\r\n\ubf08\uc5d0 \ubd99\uc740 \uc0b4\uc740 \uc694\uccad\ub4dc\ub9ac\uba74\r\n\r\n\uc774\ub807\uac8c \uc608\uc058\uac8c \ubc1c\ub77c\uc8fc\uc138\uc694.\r\n\r\n\uaf2d \ub9d0\uc500\ub4dc\ub9ac\uc138\uc694!\r\n\r\n\u200b\r\n\r\n\r\n\u200b\r\n\r\n\uc26c\ub9bc\ud504 \ub85c\uc81c \ub9ac\uac00\ud1a0\ub2c8\r\n\r\n\uace0\uae30\ub97c \uac70\uc758 \ub2e4 \uba39\uc744 \uc988\uc74c\r\n\r\n\uc26c\ub9bc\ud504 \ub85c\uc81c \ub9ac\uac00\ud1a0\ub2c8\uac00 \ub098\uc654\uc5b4\uc694.\r\n\r\n\uc0b4\uc9dd \ub9e4\ucf64\ud574\uc11c\r\n\r\n\ub9c8\ubb34\ub9ac\ub85c \uae54\ub054\ud588\uace0,\r\n\r\n\ub9ac\uac00\ud1a0\ub2c8 \uba74 \uc775\ud798\ub3c4 \ub531 \uc88b\uace0\r\n\r\n\uc18c\uc2a4\ub791\ub3c4 \uc798 \uc5b4\uc6b8\ub838\uc5b4\uc694.\r\n\r\n\ucf54\uc2a4 \ub9c8\ubb34\ub9ac\ub85c \ubd80\ub2f4 \uc5c6\uc5c8\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\ucd1d\ud3c9\r\n\r\n\uc7a0\uc2e4\uc5d0\uc11c\r\n\r\n\uc2a4\ud14c\uc774\ud06c \uba39\uace0 \uc2f6\uc744 \ub54c\r\n\r\n\ubd80\ub2f4 \uc5c6\uc774 \uc120\ud0dd\ud558\uae30 \uc88b\uc740 \uacf3\uc774\uc5d0\uc694.\r\n\r\n\ub2e4\uc74c\uc5d0\ub294 \ub2e4\ub978 \ubd80\uc704 \uba39\uc73c\ub7ec\r\n\r\n\ub610 \ubc29\ubb38\ud558\uace0 \uc2f6\uc5b4\uc694.\r\n\r\n\u200b\r\n\r\n\uac00\uac8c\uc815\ubcf4\r\n\r\n50m\r\n\r\n\u00a9 NAVER Corp.\r\n\ub189\uc2a4 \uc7a0\uc2e4\uc810\r\n\uc11c\uc6b8\ud2b9\ubcc4\uc2dc \uc1a1\ud30c\uad6c \uc0bc\ud559\uc0ac\ub85c 96 2\uce35, 3\uce35\r\n\r\n\uc608\uc57d\r\n#\ub189\uc2a4\uc7a0\uc2e4\uc810 #\ub189\uc2a4 #\uc7a0\uc2e4\uc2a4\ud14c\uc774\ud06c #\uc7a0\uc2e4\ub9db\uc9d1 #\uc7a0\uc2e